generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GuestSex {
  male
  female
  unknown
}

enum GuestAgeCategory {
  adult
  teen
  child
  small_child
  toddler_0_2
}

enum WeddingEventType {
  wedding
  afterparty
  bachelor
  bachelorette
  other
}

enum EventInvitationStatus {
  not_invited
  invited
}

enum EventRsvpStatus {
  unknown
  confirmed
  declined
  maybe
}

enum HouseholdMemberRole {
  adult
  child
}

enum VendorPaymentStatus {
  not_started
  partial
  paid
  canceled
}

enum ExpenseStatus {
  planned
  committed
  paid
  reimbursed
  canceled
}

enum WeddingTaskStatus {
  todo
  in_progress
  done
}

enum WeddingTaskPriority {
  low
  medium
  high
}

enum WeddingMemberRole {
  owner
  editor
  viewer
}

enum AppRole {
  SUPERADMIN
  ADMIN
  USER
}

model Wedding {
  id        String   @id @default(cuid())
  ownerId   String?
  owner     User?    @relation("WeddingOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  name      String
  date      DateTime?
  timezone  String?
  location  String?
  currency  String   @default("PLN")
  notes     String?
  coverImageUrl        String?
  coverImagePublicId   String?
  coverImageWidth      Int?
  coverImageHeight     Int?
  coverImageUploadedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events WeddingEvent[]
  guests Guest[]
  households Household[]
  guestGroups WeddingGuestGroup[]
  vendors Vendor[]
  expenses Expense[]
  planningNotes WeddingNote[]
  documents WeddingDocument[]
  tasks WeddingTask[]
  taskGroups WeddingTaskGroup[]
  memberships WeddingMembership[]

  @@index([ownerId])
}

model WeddingNote {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
  @@index([weddingId, pinned])
}

model WeddingEvent {
  id        String           @id @default(cuid())
  weddingId String
  wedding   Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  type      WeddingEventType @default(wedding)
  startsAt  DateTime?
  location  String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  seatingPlans SeatingPlan[]
  eventGuests  EventGuest[]
  vendorEvents VendorEvent[]
  expenses Expense[]
  timelineItems EventTimelineItem[]
  documents WeddingDocument[]
  tasks WeddingTask[]

  @@index([weddingId])
}

model EventTimelineItem {
  id        String       @id @default(cuid())
  eventId   String
  event     WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time      String
  title     String
  notes     String?
  sortOrder Int          @default(0)
  completed Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([eventId])
  @@index([eventId, sortOrder])
}

model SeatingPlan {
  id        String   @id @default(cuid())
  eventId   String?
  event     WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  name      String
  isPublicRead Boolean @default(false)
  planVersion Int @default(0)
  width     Int      @default(1600)
  height    Int      @default(1000)
  pairSidePreference String @default("auto")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables       SeatingTable[]
  groups       SeatingGuestGroup[]
  guests       Guest[]
  assignments  SeatAssignment[]
  relationships SeatingRelationship[]

  @@index([eventId])
}

model SeatingTable {
  id        String      @id @default(cuid())
  planId    String
  plan      SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  label     String
  type      String      @default("rectangle")
  x         Int
  y         Int
  rotation  Int         @default(0)
  seatCount Int
  seatLayout String     @default("balanced")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments SeatAssignment[]
  plannedGuests Guest[] @relation("PlannedTableGuests")

  @@index([planId])
}

model Guest {
  id        String      @id @default(cuid())
  planId    String
  plan      SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  weddingId String?
  wedding   Wedding?    @relation(fields: [weddingId], references: [id], onDelete: SetNull)
  name      String
  sex       GuestSex    @default(unknown)
  ageCategory GuestAgeCategory @default(adult)
  groupId   String?
  group     SeatingGuestGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  plannedTableId String?
  plannedTable SeatingTable? @relation("PlannedTableGuests", fields: [plannedTableId], references: [id], onDelete: SetNull)
  dietaryRestrictions String?
  notes     String?
  isPlaceholderPlusOne Boolean @default(false)
  plusOneHostGuestId String?
  plusOneHostGuest Guest? @relation("PlusOneHost", fields: [plusOneHostGuestId], references: [id], onDelete: SetNull)
  plusOneGuests Guest[] @relation("PlusOneHost")
  guardianGuestId String?
  guardianGuest Guest? @relation("GuestGuardian", fields: [guardianGuestId], references: [id], onDelete: SetNull)
  childGuests Guest[] @relation("GuestGuardian")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  assignments SeatAssignment[]
  relationshipMembers SeatingRelationshipMember[]
  eventGuests EventGuest[]
  householdMembership HouseholdMember?
  weddingGroupMemberships WeddingGuestGroupMember[]

  @@index([planId])
  @@index([weddingId])
  @@index([groupId])
  @@index([ageCategory])
  @@index([plannedTableId])
  @@index([plusOneHostGuestId])
  @@index([guardianGuestId])
}

model Household {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members HouseholdMember[]

  @@index([weddingId])
}

model HouseholdMember {
  id          String              @id @default(cuid())
  householdId String
  household   Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  guestId     String
  guest       Guest               @relation(fields: [guestId], references: [id], onDelete: Cascade)
  role        HouseholdMemberRole @default(adult)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([householdId, guestId])
  @@unique([guestId])
  @@index([householdId])
  @@index([guestId])
}

model WeddingGuestGroup {
  id             String   @id @default(cuid())
  weddingId      String
  wedding        Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name           String
  nameNormalized String
  color          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships WeddingGuestGroupMember[]

  @@index([weddingId])
  @@unique([weddingId, nameNormalized])
}

model WeddingGuestGroupMember {
  id        String           @id @default(cuid())
  groupId   String
  group     WeddingGuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  guestId   String
  guest     Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([groupId, guestId])
  @@index([groupId])
  @@index([guestId])
}

model Vendor {
  id             String             @id @default(cuid())
  weddingId      String
  wedding        Wedding            @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name           String
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  totalCostMinor Int                @default(0)
  depositMinor   Int                @default(0)
  amountPaidMinor Int               @default(0)
  paymentStatus  VendorPaymentStatus @default(not_started)
  dueDate        DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  vendorEvents VendorEvent[]
  expenses Expense[]
  documents WeddingDocument[]

  @@index([weddingId])
}

model WeddingDocument {
  id          String        @id @default(cuid())
  weddingId   String
  wedding     Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  eventId     String?
  event       WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  vendorId    String?
  vendor      Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  name        String
  category    String
  ownerName   String?
  status      String        @default("draft")
  externalUrl String?
  notes       String?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([weddingId])
  @@index([eventId])
  @@index([vendorId])
  @@index([status])
}

model WeddingTaskGroup {
  id             String   @id @default(cuid())
  weddingId      String
  wedding        Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name           String
  nameNormalized String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks WeddingTask[]

  @@unique([weddingId, nameNormalized])
  @@index([weddingId])
}

model WeddingTask {
  id                   String              @id @default(cuid())
  weddingId            String
  wedding              Wedding             @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  eventId              String?
  event                WeddingEvent?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  groupId              String?
  group                WeddingTaskGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  assigneeMembershipId String?
  assigneeMembership   WeddingMembership?  @relation(fields: [assigneeMembershipId], references: [id], onDelete: SetNull)
  title                String
  dueDate              DateTime?
  priority             WeddingTaskPriority @default(medium)
  status               WeddingTaskStatus   @default(todo)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  checklistItems WeddingTaskChecklistItem[]

  @@index([weddingId])
  @@index([eventId])
  @@index([groupId])
  @@index([assigneeMembershipId])
  @@index([weddingId, status])
  @@index([weddingId, dueDate])
}

model WeddingTaskChecklistItem {
  id        String      @id @default(cuid())
  taskId    String
  task      WeddingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean     @default(false)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([taskId])
  @@index([taskId, sortOrder])
}

model VendorEvent {
  id        String      @id @default(cuid())
  vendorId  String
  vendor    Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  eventId   String
  event     WeddingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([vendorId, eventId])
  @@index([vendorId])
  @@index([eventId])
}

model Expense {
  id         String       @id @default(cuid())
  weddingId  String
  wedding    Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  eventId    String?
  event      WeddingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  vendorId   String?
  vendor     Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  title      String
  category   String
  amountMinor Int
  currency   String       @default("PLN")
  incurredAt DateTime     @default(now())
  paidBy     String?
  notes      String?
  status     ExpenseStatus @default(planned)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([weddingId])
  @@index([eventId])
  @@index([vendorId])
  @@index([category])
  @@index([status])
}

model EventGuest {
  id               String                @id @default(cuid())
  eventId          String
  event            WeddingEvent          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestId          String
  guest            Guest                 @relation(fields: [guestId], references: [id], onDelete: Cascade)
  invitationStatus EventInvitationStatus @default(invited)
  rsvpStatus       EventRsvpStatus       @default(confirmed)
  requiresSeat     Boolean               @default(true)
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([eventId, guestId])
  @@index([eventId])
  @@index([guestId])
  @@index([requiresSeat])
  @@index([rsvpStatus])
}

model SeatingGuestGroup {
  id             String      @id @default(cuid())
  planId         String
  plan           SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name           String
  nameNormalized String
  color          String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  guests Guest[]

  @@index([planId])
  @@unique([planId, nameNormalized])
}

model SeatingRelationship {
  id                  String   @id @default(cuid())
  planId              String
  plan                SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  type                String
  name                String?
  preferredSeating    String
  moveTogetherDefault Boolean  @default(false)
  strict              Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  members SeatingRelationshipMember[]

  @@index([planId])
}

model SeatingRelationshipMember {
  id             String   @id @default(cuid())
  relationshipId String
  relationship   SeatingRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  guestId        String
  guest          Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  sortOrder      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([relationshipId, guestId])
  @@unique([guestId])
  @@index([relationshipId])
  @@index([guestId])
}

model SeatAssignment {
  id         String      @id @default(cuid())
  planId     String
  plan       SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tableId    String
  table      SeatingTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guestId    String
  guest      Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  seatNumber Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([planId, guestId])
  @@unique([planId, tableId, seatNumber])
  @@index([planId])
  @@index([tableId])
  @@index([guestId])
}

model User {
  id            String    @id
  name          String
  email         String
  role          AppRole   @default(USER)
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  ownedWeddings Wedding[] @relation("WeddingOwner")
  weddingMemberships WeddingMembership[]

  @@unique([email])
  @@map("user")
}

model WeddingMembership {
  id        String           @id @default(cuid())
  weddingId String
  wedding   Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      WeddingMemberRole
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  assignedTasks WeddingTask[]

  @@unique([weddingId, userId])
  @@index([weddingId])
  @@index([userId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
