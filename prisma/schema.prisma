generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SeatingPlan {
  id        String   @id @default(cuid())
  name      String
  width     Int      @default(1600)
  height    Int      @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables       SeatingTable[]
  guests       Guest[]
  assignments  SeatAssignment[]
  relationships SeatingRelationship[]
}

model SeatingTable {
  id        String      @id @default(cuid())
  planId    String
  plan      SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  label     String
  type      String      @default("rectangle")
  x         Int
  y         Int
  rotation  Int         @default(0)
  seatCount Int
  seatLayout String     @default("balanced")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments SeatAssignment[]

  @@index([planId])
}

model Guest {
  id        String      @id @default(cuid())
  planId    String
  plan      SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name      String
  group     String?
  notes     String?
  isPlaceholderPlusOne Boolean @default(false)
  plusOneHostGuestId String?
  plusOneHostGuest Guest? @relation("PlusOneHost", fields: [plusOneHostGuestId], references: [id], onDelete: SetNull)
  plusOneGuests Guest[] @relation("PlusOneHost")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  assignment SeatAssignment?
  relationshipMembers SeatingRelationshipMember[]

  @@index([planId])
  @@index([plusOneHostGuestId])
}

model SeatingRelationship {
  id                  String   @id @default(cuid())
  planId              String
  plan                SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  type                String
  name                String?
  preferredSeating    String
  moveTogetherDefault Boolean  @default(false)
  strict              Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  members SeatingRelationshipMember[]

  @@index([planId])
}

model SeatingRelationshipMember {
  id             String   @id @default(cuid())
  relationshipId String
  relationship   SeatingRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  guestId        String
  guest          Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  sortOrder      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([relationshipId, guestId])
  @@unique([guestId])
  @@index([relationshipId])
  @@index([guestId])
}

model SeatAssignment {
  id         String      @id @default(cuid())
  planId     String
  plan       SeatingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tableId    String
  table      SeatingTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guestId    String      @unique
  guest      Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  seatNumber Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([planId, tableId, seatNumber])
  @@index([planId])
  @@index([tableId])
  @@index([guestId])
}
